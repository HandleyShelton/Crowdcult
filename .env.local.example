# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Mux API credentials (for uploading / managing assets)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Mux signing key (for signed playback tokens — create in Mux Dashboard > Settings > Signing Keys)
MUX_SIGNING_KEY_ID=
# Base64-encoded RSA private key from Mux
MUX_SIGNING_PRIVATE_KEY=

# Mux webhook secret (set in Mux Dashboard > Settings > Webhooks)
MUX_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
PLATFORM_ENABLED=true

# Admin — comma-separated list of admin email addresses
ADMIN_EMAIL=you@example.com
